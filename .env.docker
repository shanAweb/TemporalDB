# ── App ──────────────────────────────────────────────
DEBUG=false
API_KEY=changeme

# ── PostgreSQL ───────────────────────────────────────
# Inside Docker network, use service name "postgres" and internal port 5432
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=temporaldb
POSTGRES_PASSWORD=temporaldb
POSTGRES_DB=temporaldb

# ── Neo4j ────────────────────────────────────────────
# Inside Docker network, use service name "neo4j" and internal port 7687
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=temporaldb

# ── Redis ────────────────────────────────────────────
# Inside Docker network, use service name "redis" and internal port 6379
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ── Kafka / Redpanda ─────────────────────────────────
# Inside Docker network, use service name "redpanda" and internal port 9092
KAFKA_BOOTSTRAP_SERVERS=redpanda:9092
KAFKA_INGESTION_TOPIC=document.ingested
KAFKA_CONSUMER_GROUP=temporaldb-nlp

# ── Ollama ───────────────────────────────────────────
# host.docker.internal lets containers reach services on the host machine
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_SYNTHESIS_MODEL=llama3.1:8b
OLLAMA_CODEGEN_MODEL=codellama:7b
OLLAMA_REQUEST_TIMEOUT=120.0

# ── NLP ──────────────────────────────────────────────
SPACY_MODEL=en_core_web_trf
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# ── Server ───────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
